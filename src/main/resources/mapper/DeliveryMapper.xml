<?xml version="1.0" encoding="UTF-8"?>
<!DOCTYPE mapper PUBLIC "-//mybatis.org//DTD Mapper 3.0//EN"
        "http://mybatis.org/dtd/mybatis-3-mapper.dtd">
<mapper namespace="com.jobplus.mapper.DeliveryMapper">

    <resultMap id="deliveryMap" type="com.jobplus.entity.Delivery">
        <id property="id" column="id"/>
        <result property="userId" column="user_id"/>
        <result property="positionId" column="position_id"/>
        <result property="resumeId" column="resume_id"/>
        <result property="status" column="status"/>
        <result property="companyRead" column="company_read"/>
        <result property="readAt" column="read_at"/>
        <result property="createdAt" column="created_at"/>
        <result property="updatedAt" column="updated_at"/>
    </resultMap>

    <select id="findById" resultMap="deliveryMap">
        SELECT * FROM delivery WHERE id = #{id}
    </select>

    <select id="findByUserAndPosition" resultMap="deliveryMap">
        SELECT * FROM delivery WHERE user_id = #{userId} AND position_id = #{positionId}
    </select>

    <insert id="insert" parameterType="com.jobplus.entity.Delivery" useGeneratedKeys="true" keyProperty="id">
        INSERT INTO delivery (user_id, position_id, resume_id, status, company_read)
        VALUES (#{userId}, #{positionId}, #{resumeId}, #{status}, #{companyRead})
    </insert>

    <update id="updateStatus">
        UPDATE delivery SET status = #{status} WHERE id = #{id}
    </update>

    <update id="markRead">
        UPDATE delivery SET company_read = TRUE, read_at = NOW() WHERE id = #{id}
    </update>

    <select id="findByUserId" resultMap="deliveryMap">
        SELECT * FROM delivery WHERE user_id = #{userId} ORDER BY created_at DESC
    </select>

    <select id="findByCompanyId" resultMap="deliveryMap">
        SELECT d.* FROM delivery d
        JOIN position p ON d.position_id = p.id
        WHERE p.company_id = #{companyId}
        ORDER BY d.created_at DESC
    </select>

    <select id="count" resultType="long">
        SELECT COUNT(*) FROM delivery
    </select>
</mapper>
