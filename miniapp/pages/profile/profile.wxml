<view class="container">
  <view wx:if="{{!user}}" class="login-box">
    <view class="title">JobPlus</view>
    <input placeholder="邮箱" value="{{email}}" bindinput="onEmail" class="input" />
    <input placeholder="密码" password value="{{password}}" bindinput="onPwd" class="input" />
    <button type="primary" bindtap="login">登录</button>
  </view>
  <view wx:else>
    <view class="header">
      <view class="name">{{user.nickname || user.email}}</view>
      <view class="role">{{['','求职者','企业','管理员'][user.role]}}</view>
    </view>
    <view class="menu-list">
      <view class="menu-item" bindtap="goResume">我的简历</view>
      <view class="menu-item" bindtap="goFavorites">我的收藏</view>
      <view class="menu-item" bindtap="goDeliveries">投递记录</view>
    </view>
    <button bindtap="logout" style="margin:30rpx">退出登录</button>
  </view>
</view>
