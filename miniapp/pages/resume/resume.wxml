<view class="container" wx:if="{{resume}}">
  <view class="card">
    <view class="title">基本信息</view>
    <view class="row"><text class="label">姓名</text><input value="{{resume.realName}}" bindinput="onField" data-field="realName" /></view>
    <view class="row"><text class="label">性别</text><input value="{{resume.gender}}" bindinput="onField" data-field="gender" /></view>
    <view class="row"><text class="label">电话</text><input value="{{resume.phone}}" bindinput="onField" data-field="phone" /></view>
    <view class="row"><text class="label">学历</text><input value="{{resume.education}}" bindinput="onField" data-field="education" /></view>
    <view class="row"><text class="label">学校</text><input value="{{resume.school}}" bindinput="onField" data-field="school" /></view>
    <view class="row"><text class="label">专业</text><input value="{{resume.major}}" bindinput="onField" data-field="major" /></view>
    <view class="row"><text class="label">毕业年份</text><input value="{{resume.graduationYear}}" bindinput="onField" data-field="graduationYear" /></view>
    <view class="row"><text class="label">技能</text><input value="{{resume.skillTags}}" bindinput="onField" data-field="skillTags" placeholder="逗号分隔" /></view>
    <view class="title" style="margin-top:30rpx">自我评价</view>
    <textarea value="{{resume.selfEvaluation}}" bindinput="onField" data-field="selfEvaluation" style="width:100%;height:200rpx;border:1px solid #eee;padding:16rpx;border-radius:8rpx" />
    <button type="primary" bindtap="save" style="margin-top:30rpx">保存</button>
  </view>
</view>
