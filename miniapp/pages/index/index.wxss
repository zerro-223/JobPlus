.hero { background:linear-gradient(135deg,#1a1a2e,#16213e);padding:40rpx 30rpx;color:#fff;text-align:center }
.hero-title { font-size:48rpx;font-weight:bold }
.hero-sub { font-size:28rpx;color:#aaa;margin:10rpx 0 30rpx }
.search-box { display:flex;background:#fff;border-radius:40rpx;padding:6rpx 20rpx }
.search-box input { flex:1;padding:16rpx 0;font-size:28rpx }
.section { padding:30rpx }
.section-title { font-size:32rpx;font-weight:bold;margin-bottom:20rpx }
.tags { display:flex;flex-wrap:wrap;gap:16rpx }
.tag { background:#e6f7ff;color:#1890ff;padding:12rpx 24rpx;border-radius:8rpx;font-size:26rpx }
.job-card { background:#fff;padding:24rpx;margin-bottom:16rpx;border-radius:12rpx;box-shadow:0 2rpx 8rpx rgba(0,0,0,.06) }
.job-title { font-size:30rpx;font-weight:bold;margin-bottom:8rpx }
.job-salary { color:#1890ff;font-size:32rpx;margin-bottom:8rpx }
.job-info { color:#666;font-size:24rpx }
.empty { text-align:center;color:#999;padding:60rpx }
