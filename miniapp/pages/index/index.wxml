<view>
  <view class="hero">
    <view class="hero-title">JobPlus</view>
    <view class="hero-sub">找到属于你的理想工作</view>
    <view class="search-box">
      <input placeholder="搜索职位/公司" bindinput="onKeyword" value="{{keyword}}" />
      <button size="mini" type="primary" bindtap="search">搜索</button>
    </view>
  </view>
  <view class="section">
    <view class="section-title">热门分类</view>
    <view class="tags">
      <view class="tag" wx:for="{{categories}}" wx:key="id" bindtap="goCategory">{{item.name}}</view>
    </view>
  </view>
  <view class="section">
    <view class="section-title">推荐职位</view>
    <view class="job-card" wx:for="{{positions}}" wx:key="id" bindtap="goDetail" data-id="{{item.id}}">
      <view class="job-title">{{item.title}}</view>
      <view class="job-salary">{{item.salaryMin}}-{{item.salaryMax}}K</view>
      <view class="job-info">{{item.companyName}} | {{item.workplace}} | {{item.education}}</view>
    </view>
    <view class="empty" wx:if="{{positions.length===0}}">暂无推荐职位</view>
  </view>
</view>
